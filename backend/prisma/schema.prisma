// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// status values match your TRANSITIONS map: draft -> issued -> paid (+ cancelled)
enum InvoiceStatus {
  draft
  issued
  paid
  cancelled
}

model User {
  id              Int     @id @default(autoincrement())
  email           String  @unique @db.VarChar(255) // login identifier
  passwordHash    String  @map("password_hash") @db.VarChar(255)
  displayName     String? @map("display_name") @db.VarChar(60) // app-only label
  role            String  @default("user") @db.VarChar(50)
  isActive        Boolean @default(true) @map("is_active") // enforced at sign-in (403 if false)
  invoiceCounter  Int     @default(0) @map("invoice_counter") // drives the private per-user sequence

  // business profile - snapshotted onto each invoice's billFrom at creation
  businessName          String? @map("business_name") @db.VarChar(255)
  businessEmail        String? @map("business_email") @db.VarChar(255)
  businessAddress      String? @map("business_address") @db.VarChar(255)
  phone                 String? @db.VarChar(50)
  paymentInstructions   String? @map("payment_instructions") @db.Text

  clients  Client[] // one user has many clients
  invoices Invoice[] // one user has many invoices

  @@map("users")

}

model Client {
  id              Int     @id @default(autoincrement())
  userId          Int     @map("user_id")
  companyName     String  @map("company_name") @db.VarChar(255)
  billingAddress  String  @map("billing_address") @db.VarChar(255)
  companyEmail    String  @map("company_email") @db.VarChar(255)
  
  user  User    @relation(fields: [userId], references: [id])
  invoices Invoice[]

  @@map("clients")
}

model Invoice {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  clientId        Int           @map("client_id")
  invoiceName           String        @default("") @db.VarChar(255) // invoice name; required by the controller, default eases migrating existing rows
  invoiceSeq      Int?          @map("invoice_seq")     //private per-user sequence, set at issue
  invoiceNumber   String?       @map("invoice_number") @db.VarChar(255) // opaque public code, set at issue
  issueDate       DateTime      @map("issue_date") @db.Date
  dueDate         DateTime      @map("due_date") @db.Date
  subtotal        Decimal       @db.Decimal(10, 2)
  taxRate         Decimal       @map("tax_rate") @db.Decimal(5,2)
  notes           String?       @db.VarChar(255) // optional
  term            String?       @db.VarChar(255) // optional
  billFrom        Json?         @map("bill_from") // snapshot of sender's profile, copied at create
  status          InvoiceStatus @default(draft)
  paidAt          DateTime?     @map("paid_at") @db.Date // nullable, set when paid; dashboard groups by this
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at") // Prisma maintains this automatically

  user  User  @relation(fields: [userId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
  lineItems LineItem[]

  @@unique([userId, invoiceSeq])
  @@unique([userId, invoiceNumber])
  @@map("invoices")
}

model LineItem {
  id             Int      @id @default(autoincrement())
  invoiceId      Int      @map("invoice_id")
  gigRole        String?  @map("gig_role") @db.VarChar(255)
  gigDescription String?  @map("gig_description") @db.VarChar(255)
  quantity       Decimal? @db.Decimal(10, 2)
  unitCost       Decimal? @map("unit_cost") @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("line_items")
}